# Copy to clickhouse.trx_inbound.env before starting the TRX inbound contour.
CLICKHOUSE_HOST=__SET_PRIVATE_ENDPOINT_HOST__
CLICKHOUSE_PORT=9440
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=tron_trx_local
CLICKHOUSE_SECURE=1
LOADER_VENV_DIR=/srv/local-tron-usdt-backfill/.venvs/loader
LOADER_PYTHON_BIN=/srv/local-tron-usdt-backfill/.venvs/loader/bin/python
LOADER_CONCURRENCY=2
LOADER_MAX_SLOTS=2
LOADER_PROFILE=trx_inbound
LOADER_SOURCE_STREAM_NAME=trx_inbound_transfer
LOADER_SOURCE_TRIGGER_NAME=transactionTrigger
LOADER_RECORD_BATCH_SIZE=350000
LOADER_BUILD_LEGS_IN_HOT_PATH=0
LOADER_SKIP_PER_SEGMENT_CANONICAL_COUNTS=1
LOADER_SEGMENT_STALE_SECONDS=1800
LOADER_RUNTIME_LOCK_STALE_SECONDS=1800
LOADER_FAILED_RETRY_BACKOFF_SECONDS=120
LOADER_MAX_ATTEMPTS=5
LOADER_SQLITE_BUSY_TIMEOUT_MS=30000
LOADER_DB_PATH=/srv/local-tron-usdt-backfill/runtime/loader_state_trx_inbound.sqlite
LOADER_SCHEMA_PATH=/srv/local-tron-usdt-backfill/loader/sql/020_loader_state.sql
LOADER_RUN_ID=tron-trx-backfill-__SET_AT_RUNTIME__
LOADER_UNIT_BASENAME=local-tron-trx-incremental-loader
AWS_REGION=eu-central-1
S3_BUFFER_BUCKET=goldusdt-v2-stage-913378704801-raw
S3_BUFFER_PREFIX_ROOT=providers/tron-usdt-backfill/usdt-transfer-oneoff
RAW_DIR=/srv/local-tron-usdt-backfill/raw
REPORT_DIR=/srv/local-tron-usdt-backfill/reports
RUNTIME_DIR=/srv/local-tron-usdt-backfill/runtime
# Use when applying schema:
# CLICKHOUSE_SCHEMA_SQL_PATH=/srv/local-tron-usdt-backfill/sql/clickhouse/011_trx_inbound_schema.sql
