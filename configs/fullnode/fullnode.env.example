AWS_PROFILE=ai-agents-dev
AWS_REGION=ap-southeast-1

PROJECT_TAG=local-tron-usdt-backfill
PROJECT_OWNER=codex
INSTANCE_NAME=local-tron-usdt-backfill-block02

INSTANCE_TYPE=i4i.4xlarge
ROOT_VOLUME_SIZE_GB=120
AMI_SSM_PARAMETER=/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-default-x86_64
PREFERRED_AZ=ap-southeast-1a
SUBNET_ID=
VPC_ID=

INSTANCE_ROLE_NAME=local-tron-usdt-backfill-ssm-role
INSTANCE_PROFILE_NAME=local-tron-usdt-backfill-ssm-profile
SECURITY_GROUP_NAME=local-tron-usdt-backfill-noingress

TRON_RELEASE_TAG=GreatVoyage-v4.8.1
TRON_RELEASE_JAR=FullNode-x64.jar
TRON_CONFIG_URL=https://raw.githubusercontent.com/tronprotocol/java-tron/GreatVoyage-v4.8.1/framework/src/main/resources/config.conf

WORKSPACE_ROOT=/srv/local-tron-usdt-backfill
EXTRACTOR_ENV_FILE=/srv/local-tron-usdt-backfill/configs/extractor/extractor.env
TRON_HOME=/opt/tron/fullnode
TRON_CONFIG_PATH=/opt/tron/fullnode/config/config.conf
TRON_DATA_DIR=/tron-data/java-tron
TRON_LOG_DIR=/var/log/tron
TRON_USER=tron
TRON_HTTP_PORT=8090
TRON_ENABLE_EVENT_SERVICE=0
TRON_JAVA_OPTS=-Xms16G -Xmx48G -XX:+UseG1GC

TRON_SNAPSHOT_BASE_URL=http://35.197.17.205
TRON_SNAPSHOT_ARCHIVE=FullNode_output-directory.tgz
TRON_SNAPSHOT_URL=
